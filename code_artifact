                <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden">
                    <button onclick="toggleFaq(3)" class="w-full px-6 py-4 text-left font-bold text-white hover:text-brand flex justify-between items-center transition-colors">
                        <span>手機架有提供保固或安裝服務嗎？</span>
                        <i id="faq-icon-3" class="fa-solid fa-chevron-down text-xs transition-transform"></i>
                    </button>
                    <div id="faq-ans-3" class="hidden px-6 pb-5 text-sm text-slate-400 border-t border-slate-800/50 pt-3">
                        有的！只要在此一頁式特價檔期購買手機架，到店取貨即可享有「現場免費專業安裝與調校」服務（不收安裝費）。產品自取貨日起，皆享有非人為損壞保固七天，新品瑕疵直接現場換新。
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 頁尾 -->
    <footer class="bg-slate-950 py-12 px-6 border-t border-slate-900 text-center space-y-6">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="flex items-center gap-2">
                <div class="bg-brand text-white p-2 rounded-lg font-black text-lg italic tracking-wider">
                    CY-MOTO
                </div>
                <div class="text-left">
                    <span class="font-bold text-base leading-none block text-white">嘉義機車用品</span>
                    <span class="text-[10px] text-slate-500">版權所有 © 2026 嘉義機車用品店. All Rights Reserved.</span>
                </div>
            </div>
            <div class="flex gap-4 text-slate-400 text-xs">
                <span class="hover:text-brand cursor-pointer">隱私權政策</span>
                <span>|</span>
                <span class="hover:text-brand cursor-pointer">服務條款</span>
                <span>|</span>
                <span class="hover:text-brand cursor-pointer">門市退換貨須知</span>
            </div>
        </div>
    </footer>

    <!-- 成功訂購彈窗 (非原生 alert) -->
    <div id="successModal" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 flex items-center justify-center p-4 hidden">
        <div class="bg-slate-900 border border-slate-800 max-w-md w-full rounded-3xl p-8 text-center space-y-6 animate-slide-in relative">
            <div class="w-20 h-20 bg-emerald-500/10 text-emerald-500 rounded-full flex items-center justify-center text-4xl mx-auto border border-emerald-500/20">
                <i class="fa-solid fa-circle-check"></i>
            </div>
            
            <div class="space-y-2">
                <h3 class="text-2xl font-black text-white">🎉 搶購登記成功！</h3>
                <p class="text-slate-400 text-sm">我們已為您鎖定保留限量名額！</p>
            </div>

            <!-- 訂單摘要 -->
            <div class="bg-slate-950 p-4 rounded-2xl border border-slate-800 text-left space-y-2 text-xs md:text-sm">
                <p class="text-slate-400">訂購姓名：<span id="resName" class="text-white font-bold"></span></p>
                <p class="text-slate-400">聯絡電話：<span id="resPhone" class="text-white font-bold"></span></p>
                <p class="text-slate-400">保留商品：<span id="resProduct" class="text-brand font-bold"></span></p>
                <p class="text-slate-400">總計金額：<span class="text-emerald-400 font-bold">TWD $ <span id="resPrice"></span></span></p>
                <p class="text-slate-400">領取方式：<span id="resDelivery" class="text-white font-bold"></span></p>
            </div>

            <p class="text-xs text-orange-400">門市專員將於 24 小時內致電確認細節，請保持電話暢通！</p>

            <button onclick="closeModal()" class="w-full bg-slate-800 hover:bg-slate-700 text-white font-bold py-3.5 px-6 rounded-xl transition-all">
                好的，我知道了
            </button>
        </div>
    </div>

    <!-- 實時動態訂單氣泡 (增加 FOMO 熱銷感) -->
    <div id="fomoBubble" class="fixed bottom-6 left-6 z-40 bg-slate-950/90 border border-slate-800 p-4 rounded-2xl shadow-2xl flex items-center gap-3 max-w-sm hidden transition-all duration-500 hover:scale-105">
        <div class="w-10 h-10 rounded-full bg-brand/10 text-brand flex items-center justify-center text-lg">
            <i class="fa-solid fa-bolt"></i>
        </div>
        <div>
            <p id="fomoText" class="text-xs text-slate-300 font-bold"></p>
            <p class="text-[10px] text-slate-500">剛剛完成限時登記</p>
        </div>
        <button onclick="hideFomo()" class="text-slate-500 hover:text-slate-300 ml-2">
            <i class="fa-solid fa-xmark text-xs"></i>
        </button>
    </div>

    <script>
        // 初始化與倒數計時
        let timer;
        function startCountdown() {
            let hours = 2;
            let minutes = 14;
            let seconds = 35;

            timer = setInterval(() => {
                if (seconds > 0) {
                    seconds--;
                } else {
                    if (minutes > 0) {
                        minutes--;
                        seconds = 59;
                    } else {
                        if (hours > 0) {
                            hours--;
                            minutes = 59;
                            seconds = 59;
                        } else {
                            // 時間到，重設一個模擬時間保持網頁銷售感
                            hours = 3;
                            minutes = 45;
                            seconds = 12;
                        }
                    }
                }
                document.getElementById('countdown-hours').textContent = String(hours).padStart(2, '0');
                document.getElementById('countdown-minutes').textContent = String(minutes).padStart(2, '0');
                document.getElementById('countdown-seconds').textContent = String(seconds).padStart(2, '0');
            }, 1000);
        }

        // 當點擊特惠產品的「立即搶購」時
        function selectProduct(productName, price) {
            const selectEl = document.getElementById('orderProduct');
            
            // 尋找對應的 Option 並選取它
            for (let i = 0; i < selectEl.options.length; i++) {
                if (selectEl.options[i].value === productName) {
                    selectEl.selectedIndex = i;
                    break;
                }
            }
            
            calculateTotal();

            // 平滑滾動到訂購表單
            const orderSection = document.getElementById('order-section');
            orderSection.scrollIntoView({ behavior: 'smooth' });
        }

        // 計算合計金額
        function calculateTotal() {
            const selectEl = document.getElementById('orderProduct');
            const qtyEl = document.getElementById('orderQty');
            const priceSpan = document.getElementById('totalPrice');

            const selectedOption = selectEl.options[selectEl.selectedIndex];
            if (selectedOption && selectedOption.dataset.price) {
                const unitPrice = parseInt(selectedOption.dataset.price);
                const qty = parseInt(qtyEl.value);
                priceSpan.textContent = (unitPrice * qty).toLocaleString();
            } else {
                priceSpan.textContent = '0';
            }
        }

        // 切換地址輸入欄
        function toggleAddressField(show, placeholderText) {
            const container = document.getElementById('addressContainer');
            const label = document.getElementById('addressLabel');
            const input = document.getElementById('deliveryAddress');

            if (show) {
                container.classList.remove('hidden');
                label.innerHTML = `<i class="fa-solid fa-location-dot text-brand mr-1"></i> ${placeholderText} <span class="text-brand">*</span>`;
                input.placeholder = `請填寫您的${placeholderText}`;
                input.required = true;
            } else {
                container.classList.add('hidden');
                input.required = false;
                input.value = '';
            }
        }

        // FAQ 收合與開展
        function toggleFaq(index) {
            const ans = document.getElementById(`faq-ans-${index}`);
            const icon = document.getElementById(`faq-icon-${index}`);

            if (ans.classList.contains('hidden')) {
                ans.classList.remove('hidden');
                icon.classList.add('rotate-180');
            } else {
                ans.classList.add('hidden');
                icon.classList.remove('rotate-180');
            }
        }

        // 表單送出處理
        function handleOrderSubmit(e) {
            e.preventDefault();

            // 獲取表單數值
            const product = document.getElementById('orderProduct').value;
            const qty = document.getElementById('orderQty').value;
            const name = document.getElementById('customerName').value;
            const phone = document.getElementById('customerPhone').value;
            const delivery = document.querySelector('input[name="deliveryMethod"]:checked').value;
            const address = document.getElementById('deliveryAddress').value;

            // 計算最終價格
            const selectEl = document.getElementById('orderProduct');
            const selectedOption = selectEl.options[selectEl.selectedIndex];
            const unitPrice = parseInt(selectedOption.dataset.price);
            const finalPrice = (unitPrice * qty).toLocaleString();

            // 將資料填入自訂彈窗
            document.getElementById('resName').textContent = name;
            document.getElementById('resPhone').textContent = phone;
            document.getElementById('resProduct').textContent = `${product} (${qty}件)`;
            document.getElementById('resPrice').textContent = finalPrice;
            document.getElementById('resDelivery').textContent = delivery + (address ? ` - ${address}` : '');

            // 顯示彈窗
            document.getElementById('successModal').classList.remove('hidden');
        }

        // 關閉訂單成功彈窗並重設表單
        function closeModal() {
            document.getElementById('successModal').classList.add('hidden');
            document.getElementById('orderForm').reset();
            document.getElementById('addressContainer').classList.add('hidden');
            calculateTotal();
        }

        // 實時 FOMO 氣泡效果：模擬其他人在嘉義的購買動態
        const sampleCustomers = [
            { name: "民雄 許先生", product: "五爪金屬防震減震手機架" },
            { name: "水上 曾小姐", product: "雙鏡片防霧全罩式安全帽" },
            { name: "嘉義西區 吳先生", product: "雙拉鍊高質感防風雨衣" },
            { name: "大林 賴先生", product: "機車防刮隔熱防塵車套" },
            { name: "朴子 蔡小姐", product: "雙鏡片防霧全罩式安全帽" },
            { name: "嘉義東區 李先生", product: "五爪金屬防震減震手機架" }
        ];

        function showFomo() {
            const bubble = document.getElementById('fomoBubble');
            const textEl = document.getElementById('fomoText');
            
            const randomPick = sampleCustomers[Math.floor(Math.random() * sampleCustomers.length)];
            textEl.innerHTML = `<span class="text-brand font-bold">${randomPick.name}</span> 搶購了 [${randomPick.product}]`;
            
            bubble.classList.remove('hidden');
            bubble.style.opacity = '1';

            // 7秒後自動隱藏
            setTimeout(() => {
                hideFomo();
            }, 7000);
        }

        function hideFomo() {
            const bubble = document.getElementById('fomoBubble');
            bubble.style.opacity = '0';
            setTimeout(() => {
                bubble.classList.add('hidden');
            }, 500);
        }

        // 定期重複 FOMO 購買訊息
        function startFomoCycle() {
            // 每隔 15~25 秒出現一次
            setInterval(() => {
                showFomo();
            }, Math.random() * 10000 + 15000);
        }

        // 初始化
        window.onload = function () {
            startCountdown();
            // 監聽商品更動以隨時更新總價
            document.getElementById('orderProduct').addEventListener('change', calculateTotal);
            // 啟動 FOMO 氣泡循環
            setTimeout(showFomo, 3000);
            startFomoCycle();
        };
    </script>
</body>
</html>
